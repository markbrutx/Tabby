{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tabby",
  "version": "0.1.0",
  "identifier": "com.markbrutx.tabby",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Tabby",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "width": 1600,
        "height": 980,
        "minWidth": 1120,
        "minHeight": 720,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
